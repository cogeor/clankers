# Rust build artifacts
/target/
**/*.rs.bk

# Cargo lock is committed for the workspace (binary + library)
# See: https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html

# IDE / editor
.idea/
.vscode/
.gemini/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Local secrets / env
.env

# Delegate (spec-driven workflow scratch)
.delegate/

# Notes, scratch reports, ad-hoc captures.
# Anything experimental or one-off lives here. Promote to docs/ when it earns its place.
# Use `notes/*` (not `notes/`) so we can un-ignore specific subpaths below.
notes/*
# Exception: tracked baseline CSVs for `clankers-app bench` regression
# checks (W5 PR4). The schema is LOCKED in
# apps/clankers-app/src/commands/bench.rs; W8 CI compares fresh runs
# against these committed values. Only .csv files in this directory are
# tracked — keep one row per scenario.
!notes/baselines/
notes/baselines/*
!notes/baselines/*.csv

# Generated simulation captures / datasets.
# Keep small fixtures under crates/*/tests/fixtures/ or a dedicated fixtures/ tree.
data/
output/
*.mcap

# Recorded media
*.gif
!docs/**/*.gif
*.mp4
*.webm
